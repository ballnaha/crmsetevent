generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum EventSource {
  BITEC
  IMPACT
  MANUAL
}

enum LeadStatus {
  NEW
  QUALIFIED
  CONTACTED
  PROPOSAL
  WON
  LOST
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
}

model Venue {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  website   String?
  location  String?
  events    Event[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id          Int         @id @default(autoincrement())
  title       String
  source      EventSource
  sourceUrl   String?
  category    String?
  hall        String?
  imageUrl             String?
  organizerName        String?
  organizerContactName String?
  organizerPhone       String?
  organizerEmail       String?
  organizerWebsite     String?
  organizerFacebook    String?
  outreachStatus       String   @default("NEW")
  startsAt    DateTime
  endsAt      DateTime?
  venueId     Int
  venue       Venue       @relation(fields: [venueId], references: [id])
  leads       Lead[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([source])
  @@index([startsAt])
  @@unique([title, startsAt, venueId])
}

model Lead {
  id          Int          @id @default(autoincrement())
  companyName String
  contactName String?
  phone       String?
  email       String?
  status      LeadStatus   @default(NEW)
  priority    LeadPriority @default(MEDIUM)
  note        String?      @db.Text
  eventId     Int?
  event       Event?       @relation(fields: [eventId], references: [id])
  activities  Activity[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([priority])
}

model Activity {
  id        Int      @id @default(autoincrement())
  leadId    Int
  lead      Lead     @relation(fields: [leadId], references: [id])
  title     String
  dueAt     DateTime?
  done      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([dueAt])
}
